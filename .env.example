# Skopiuj ten plik jako .env.local i uzupełnij wartości

# Webhook — opcjonalny URL do powiadamiania np. Zapier/Make/n8n
# WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxx/yyy

# MailerLite — podpięcie listy mailingowej
# MAILERLITE_API_KEY=your_api_key_here
# MAILERLITE_GROUP_ID=your_group_id_here

# Brevo (dawny SendinBlue)
# BREVO_API_KEY=your_api_key_here
# BREVO_LIST_ID=your_list_id_here
